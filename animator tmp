#!/bin/bash
set -e
source /venv/main/bin/activate

W=${WORKSPACE:-/workspace}
BASE="${W}/ComfyUI"
PORT=8188

declare -a SYS_DEPS=()
declare -a PY_DEPS=()

declare -a EXTENSIONS=(
    "https://github.com/kijai/ComfyUI-WanVideoWrapper"
    "https://github.com/chflame163/ComfyUI_LayerStyle"
    "https://github.com/yolain/ComfyUI-Easy-Use"
    "https://github.com/kijai/ComfyUI-KJNodes"
    "https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite"
    "https://github.com/kijai/ComfyUI-segment-anything-2"
    "https://github.com/cubiq/ComfyUI_essentials"
    "https://github.com/fq393/ComfyUI-ZMG-Nodes"
    "https://github.com/kijai/ComfyUI-WanAnimatePreprocess"
    "https://github.com/rgthree/rgthree-comfy"
    "https://github.com/jnxmx/ComfyUI_HuggingFace_Downloader"
    "https://github.com/weweqsueprcomfu/tsutils"
)

declare -A ASSET_MAP=(
    [clip]="
        https://huggingface.co/f5aiteam/CLIP/resolve/main/umt5_xxl_fp8_e4m3fn_scaled.safetensors
        https://huggingface.co/Comfy-Org/Wan_2.1_ComfyUI_repackaged/resolve/main/split_files/clip_vision/clip_vision_h.safetensors
    "
    [clip_vision]="
        https://huggingface.co/Comfy-Org/Wan_2.1_ComfyUI_repackaged/resolve/main/split_files/clip_vision/clip_vision_h.safetensors
    "
    [unet]="
        https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/diffusion_models/z_image_turbo_bf16.safetensors
    "
    [vae]="
        https://huggingface.co/Comfy-Org/Wan_2.1_ComfyUI_repackaged/resolve/main/split_files/vae/wan_2.1_vae.safetensors
    "
    [detection]="
        https://huggingface.co/Kijai/WanVideo_comfy_fp8_scaled/resolve/main/Wan22Animate/Wan2_2-Animate-14B_fp8_scaled_e4m3fn_KJ_v2.safetensors
        https://huggingface.co/Wan-AI/Wan2.2-Animate-14B/resolve/main/process_checkpoint/det/yolov10m.onnx
        https://huggingface.co/Kijai/vitpose_comfy/resolve/main/onnx/vitpose_h_wholebody_data.bin
        https://huggingface.co/Kijai/vitpose_comfy/resolve/main/onnx/vitpose_h_wholebody_model.onnx
    "
    [upscale_models]="
        https://huggingface.co/gazsuv/pussydetectorv4/resolve/main/4xUltrasharp_4xUltrasharpV10.pt
    "
    [loras]="
        https://huggingface.co/Kijai/WanVideo_comfy/resolve/main/Lightx2v/lightx2v_I2V_14B_480p_cfg_step_distill_rank256_bf16.safetensors
        https://huggingface.co/Comfy-Org/Wan_2.2_ComfyUI_Repackaged/resolve/main/split_files/loras/wan2.2_i2v_lightx2v_4steps_lora_v1_high_noise.safetensors
        https://huggingface.co/alibaba-pai/Wan2.2-Fun-Reward-LoRAs/resolve/main/Wan2.2-Fun-A14B-InP-low-noise-HPS2.1.safetensors
        https://huggingface.co/Kijai/WanVideo_comfy/resolve/main/Pusa/Wan21_PusaV1_LoRA_14B_rank512_bf16.safetensors
    "
    [diffusion_models]="
        https://huggingface.co/Tongyi-MAI/Z-Image/resolve/main/transformer/diffusion_pytorch_model-00001-of-00002.safetensors
        https://huggingface.co/Kijai/WanVideo_comfy_fp8_scaled/resolve/main/Wan22Animate/Wan2_2-Animate-14B_fp8_scaled_e4m3fn_KJ_v2.safetensors
    "
)

_fetch() {
    local dest="$1"; shift
    [[ $# -eq 0 ]] && return
    mkdir -p "$dest"
    for u in "$@"; do
        local hdr=""
        [[ -n "$HF_TOKEN" && "$u" == *huggingface.co* ]] && hdr="--header=Authorization: Bearer $HF_TOKEN"
        [[ -n "$CIVITAI_TOKEN" && "$u" == *civitai.com* ]] && hdr="--header=Authorization: Bearer $CIVITAI_TOKEN"
        wget $hdr -nc --content-disposition --show-progress -e dotbytes=4M -P "$dest" "$u" 2>/dev/null || true
    done
}

_ensure_repo() {
    [[ -d "$BASE" ]] || git clone https://github.com/comfyanonymous/ComfyUI.git "$BASE"
    cd "$BASE"
    [[ -f requirements.txt ]] && pip install --no-cache-dir -r requirements.txt
}

_sync_extensions() {
    local nd="${BASE}/custom_nodes"
    mkdir -p "$nd" && cd "$nd"
    for url in "${EXTENSIONS[@]}"; do
        local name="${url##*/}" target="./${name}"
        if [[ -d "$target" ]]; then
            (cd "$target" && git pull --ff-only 2>/dev/null || { git fetch && git reset --hard origin/main; })
        else
            git clone "$url" "$target" --recursive 2>/dev/null || true
        fi
        [[ -f "${target}/requirements.txt" ]] && pip install --no-cache-dir -r "${target}/requirements.txt" 2>/dev/null || true
    done
}

_resolve_assets() {
    for key in "${!ASSET_MAP[@]}"; do
        local target="${BASE}/models/${key}"
        read -ra urls <<< "${ASSET_MAP[$key]}"
        _fetch "$target" "${urls[@]}"
    done
}

_bootstrap() {
    [[ ${#SYS_DEPS[@]} -gt 0 ]] && sudo apt update && sudo apt install -y "${SYS_DEPS[@]}"
    _ensure_repo
    _sync_extensions
    [[ ${#PY_DEPS[@]} -gt 0 ]] && pip install --no-cache-dir "${PY_DEPS[@]}"
    _resolve_assets
}

[[ ! -f /.noprovisioning ]] && _bootstrap

cd "$BASE"
exec python main.py --listen 0.0.0.0 --port $PORT
